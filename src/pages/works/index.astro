---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorksGallery from '../../components/WorksGallery.astro';

const works = (await getCollection('works')).sort(
  (a, b) => a.data.order - b.data.order,
);

const description =
  "Selected oil paintings by Khin Sandar Kyaw — landscapes of Myanmar from Inle Lake, Bagan, and the Shan highlands.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: 'https://madebyksk.com/works',
  name: 'Works — Khin Sandar Kyaw',
  description,
  creator: { '@id': 'https://madebyksk.com/#person' },
  hasPart: works.map((w) => ({
    '@type': 'VisualArtwork',
    name: w.data.title,
    dateCreated: String(w.data.year),
    artMedium: w.data.medium,
    artworkSurface: w.data.dimensions ?? undefined,
    locationCreated: w.data.location ?? undefined,
    creator: { '@id': 'https://madebyksk.com/#person' },
  })),
};
---
<Base
  title="Works — Khin Sandar Kyaw"
  description={description}
  current="works"
  ogImagePath={works[0] ? `/og-works-${works[0].id}.jpg` : '/og.jpg'}
  ogImageAlt={`${works[0]?.data.title ?? 'Painting'} by Khin Sandar Kyaw — selected oil paintings from Myanmar`}
  jsonLd={jsonLd}
>
  <WorksGallery />
</Base>
