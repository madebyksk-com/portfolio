---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import WorksStrip from '../components/WorksStrip.astro';

const description =
  "Oil paintings by Khin Sandar Kyaw — a landscape painter in Yangon, Myanmar. Light, atmosphere, and rural life from Inle, Bagan, and the Shan highlands.";

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://madebyksk.com/#person',
  name: 'Khin Sandar Kyaw',
  jobTitle: 'Landscape painter',
  description,
  url: 'https://madebyksk.com',
  image: 'https://madebyksk.com/og.jpg',
  worksFor: { '@type': 'Organization', name: 'Independent studio' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Yangon',
    addressCountry: 'MM',
  },
  sameAs: [
    'https://www.instagram.com/khinsandar798',
    'https://www.facebook.com/khin.sandarphone.kyaw',
  ],
  email: 'hello@madebyksk.com',
};
---
<Base
  title="Khin Sandar Kyaw — Oil Landscape Painter from Myanmar"
  description={description}
  current="home"
  ogType="profile"
  jsonLd={jsonLd}
>
  <Hero />
  <WorksStrip />
</Base>
