---
import '../styles/global.css';
import Header from '../components/Header.astro';
import MobileNav from '../components/MobileNav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  current?: 'home' | 'works' | 'about';
  ogType?: 'website' | 'profile' | 'article';
  ogImagePath?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  current,
  ogType = 'website',
  ogImagePath = '/og.jpg',
  ogImageAlt = 'Portrait of Khin Sandar Kyaw, landscape painter from Myanmar',
  jsonLd,
} = Astro.props as Props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(ogImagePath, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF7F2" />
    <meta name="author" content="Khin Sandar Kyaw" />
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Khin Sandar Kyaw" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/antonio-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-bg text-ink font-body min-h-screen">
    <Header current={current} />
    <MobileNav current={current} />
    <main id="top" class="lg:max-w-[1280px] lg:mx-auto">
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/interactions.ts';
    </script>
  </body>
</html>
